{
  "name": "image-bird",
  "version": "1.0.0",
  "description": "The Fastify boilerplate with all you need to build your SaaS, AI tool, or any other web app and make your first $ online fast.",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node dist/main.js",
    "lint": "prettier --write --config prettier.config.js --list-different src/**/*.ts",
    "start": "node ./dist/main.js",
    "test": "tsc && jest --coverage --testPathPattern ./dist/.*\\.test\\.js$"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/qs": "^6.15.1",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@faker-js/faker": "^10.5.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "mongodb": "^7.5.0",
    "qs": "^6.15.3",
    "sharp": "^0.35.3"
  }
}
